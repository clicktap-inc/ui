{
  "name": "@clicktap/ui",
  "version": "0.34.1",
  "private": false,
  "author": "Clicktap",
  "description": "A library of React UI components and low-level hooks.",
  "keywords": [
    "react",
    "react-component",
    "clicktap"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./components/*": {
      "import": "./components/*",
      "types": "./components/*"
    },
    "./hooks/*": {
      "import": "./hooks/*",
      "types": "./hooks/*"
    },
    "./utils/*": {
      "import": "./utils/*",
      "types": "./utils/*"
    },
    "./types/*": {
      "import": "./types/*",
      "types": "./types/*"
    },
    "./assets/*": "./assets/*"
  },
  "dependencies": {
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@react-aria/interactions": "^3.21.1",
    "@react-stately/utils": "^3.9.1",
    "clsx": "2.1.1",
    "jwt-decode": "^4.0.0",
    "next": "^14.2.3",
    "react-number-format": "^5.4.0",
    "tailwind-merge": "2.5.2"
  },
  "devDependencies": {
    "@storybook/addon-actions": "^8.0.6",
    "@storybook/react": "7.4.5",
    "framer-motion": "^11.18.0",
    "glob": "^11.0.0",
    "react-aria": "^3.46.0",
    "react-aria-components": "^1.15.0",
    "tailwindcss": "^4.0.15"
  },
  "peerDependencies": {
    "@floating-ui/react": "^0.25.4",
    "@nextui-org/accordion": "^2.2.0",
    "@nextui-org/badge": "^2.2.0",
    "@nextui-org/pagination": "^2.2.0",
    "@nextui-org/tooltip": "^2.2.0",
    "@types/react": "^18.0.0",
    "framer-motion": "^11.18.0",
    "react": "^18.0.0",
    "react-aria": "^3.46.0",
    "react-aria-components": "^1.15.0",
    "react-dom": "^18.0.0",
    "react-international-phone": "^4.3.0"
  },
  "tailwind": "./tailwind.config.js",
  "scripts": {
    "preinstall": "if [ \"$INIT_CWD\" = \"$PWD\" ]; then echo 'ERROR: Run pnpm install from the monorepo root, not from this directory.' && exit 1; fi"
  }
}